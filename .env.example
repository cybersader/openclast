# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=obsidian
MINIO_ROOT_PASSWORD=change-me-in-production

# Obsidian container
PUID=1000
PGID=1000
TZ=America/New_York

# Tailscale (for multi-instance testing — Approach B)
# Generate ephemeral pre-auth keys at: https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY_ALICE=tskey-auth-xxx
TS_AUTHKEY_BOB=tskey-auth-xxx
